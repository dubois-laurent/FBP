{
  "name": "festival-booking-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "migrate": "pnpm --filter backend db:migrate",
    "studio": "pnpm --filter backend db:studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
